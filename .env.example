# Turso Database
DATABASE_URL=libsql://your-db.turso.io
DATABASE_AUTH_TOKEN=your-turso-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Clerk (admin auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Super admins now live in the `super_admins` DB table (managed at
# /admin/super/admins). Bootstrap the first row by running:
#   SUPER_ADMIN_EMAILS="your-email@example.com" npm run db:seed-super-admins

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Community service page — Amazon Wish List for the 96 Backpacks project.
# Leave empty to show "coming soon" fallback on /[slug]/community-service.
NEXT_PUBLIC_AMAZON_WISHLIST_URL=
